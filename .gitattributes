# 默认：文本文件 LF，由 Git 自动识别
* text=auto eol=lf

# Windows 批处理必须 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制资产（当前及未来）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
*.zip binary
*.7z binary
*.step binary
*.stp binary
*.stl binary
